## > test blocks, in revo

they let you keep small tests
they only run when you pass `--test`
a test run will still execute the whole module
they fail only when you return an error

##
fn add(a, b) a + b
fn multiply(a, b) a * b

# the body sees the same module scope as the rest of the file
test "addition" do
	expect(add(20, 22) == 42)?
	expect(add(20, 22) != 22)?
end

# you can also skip tests
test/skip "subtraction (not implemented)" do
  expect(sub(2, 3) == 5)?
end

# you can combine them into suites just like this
suite "math operations" do
  test "addition" do
    expect(add(1, 1) == 2)?
  end

  test "multiply" do
    expect(multiply(3, 4) == 12)?
  end
end

# despite everything, tests always evaluate to :nil
const x = test "nothing" do
	4
end
expect(x == :nil)?
