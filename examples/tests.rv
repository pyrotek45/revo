## > test blocks, in revo

they let you keep small tests
they only run when you pass `--test`
a test run will still execute the whole module
they fail only when you return an error

##
fn add(a, b) a + b
fn multiply(a, b) a * b

suite "add" do
	test "addition" do
		expect(add(20, 22) == 42)?
		expect(add(20, 22) != 22)?
	end
 
	test/skip "adds two tables" do
		expect(add({1,2}, {3, 4}) == {4,6})?
	end
end

# the body sees the same module scope as the rest of the file

# you can also skip tests
test/skip "subtraction (not implemented)" do
  expect(sub(2, 3) == 5)?
end

# you can combine them into suites just like this
suite "math operations" do
  test "addition" do
    expect(add(1, 1) == 2)?
  end

  test "multiply" do
    expect(multiply(3, 4) == 12)?
  end
end

test "fails" do
	expect(add(1,1) == 42)?
end

suite "json" do
	fn mock(i) do
		{id = i, name = "asdf"}
	end

	test "structure" do
		const data = mock(42)
		expect(data.id == 42)?
		expect(data.name == "asdf")?
	end

	test "structure multiple" do
		for i in 0..10 do
			const data = mock(i)
			expect(data.id == i)?
		end
	end
end

# despite everything, tests always evaluate to :nil
const x = test "nothing" do
4
end
assert(x == :nil)?

# later, some day
