## > proc macros, in revo

they execute any program at compile-time
they get an iterator of ast nodes inside parens
...then return the resulting ast as a tuple of nodes

macro documentation does not have to document the exact logic, only what the reasonably expected
	behavior is

an overly-verbose example is:

	# >	$format: str-literal, $any... -> print(fmt($format, $...))
	# >> printf!("hello, %s!", world)
	#		 hello, world!
	#
	# >	$any... -> print($...)
	# >> printf!("foo", "bar")
	#		 foo bar
	#
	#	prints parameters with a newline, either by a format string literal or 
	proc printf!() do ... end

##

# > any -> any
proc take1!(iter) do
	let x = iter:next()
	print(x)
  {x}
end

print(take1!(20))

proc mul!(iter) do
	let a = iter:next()
	let b = iter:next()
	
	{(:binary, :mul, a, b)}
end

print("mul 1 2: ", mul!(1, 2))

proc madd!(iter) do
	print("inner: ", mul!(1, 2))
	{(:hash, "ok")}
end

print("m add: ", madd!())

proc passthrough1!(iter) do
  let first = inspect(iter:next())
  {first}
end

proc passthrough2!(iter) do
  let first = take1!(iter:next())
  {first}
end

print(passthrough1!(42))
print(passthrough2!(42))

# > any, any, any -> any + any + any
proc add3!(iter) do
  let a = iter:next()
  let b = iter:next()
  let c = iter:next()
  {(:binary, :add, (:binary, :add, a, b), c)}
end

print(add3!(10, 20, 12))

# > num, num, num -> Sigma^4_n=1(a * b + c)
proc cmul!(iter) do
	print("inner: ", add3!(10,20,12))
	print("peek: ", iter:peek())
	match iter:peek()
	| (:number, n) print("is number", n)
	| (other, n) print(other, n)
	| x print("not tuple: ", x) # breaks right here today :(
	let a = 10 + (iter:next_of(:number))
  let b = iter:next_of(:number)
  let c = iter:next_of(:number)
	let acc = 0
	for i in 1..5 do
		acc += a * b + c
	end

  {(:number, acc)}
end

print(cmul!(10,20,30))

# > ...any -> #(any + any)
proc fold_add!(iter) do
  let acc = iter:next()

  while iter:peek() != :nil do
    let nxt = iter:next()
    acc = (:binary, :add, acc, nxt)
  end

  {acc}
end

print(fold_add!(10, 20, 5, 7))

# > bool, any, any -> if bool any else any
proc choose!(iter) do
  let cond = iter:next()
  let yes = iter:next()
  let no = iter:next()
  {(:if_expr, cond, yes, no)}
end

print(choose!(2 == 3, 1, 0))
print(choose!(2 == 2, 1, 0))
