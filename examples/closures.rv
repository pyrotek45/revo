fn make_counter() do
    let x = 0
    fn() do x = x + 1  x end
end

const c = make_counter()
print(c()) # 1
print(c()) # 2

# comp closures
const x = comp do
	let res = io:read():unwrap()
		|> fn(c) c:upper()

	match res
	| "HELLO" when io:read():unwrap():len() < 2
		{}:set_meta({
				__index = fn(self, k) k * 2
		})
	| x
	when do
		let u = x
		print(u)
	end :ok
end
